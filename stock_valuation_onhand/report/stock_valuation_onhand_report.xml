<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_stock_valuation_onhand" model="ir.actions.report">
        <field name="name">Inventory Valuation On-Hand</field>
        <field name="model">stock.valuation.onhand.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">
            stock_valuation_onhand.report_stock_valuation_onhand_template
        </field>
        <field name="report_file">
            stock_valuation_onhand.report_stock_valuation_onhand_template
        </field>
        <field name="print_report_name">
            'Inventory_Valuation_OnHand_%s' % (object.date)
        </field>
        <field name="binding_model_id"
               ref="stock_valuation_onhand.model_stock_valuation_onhand_wizard" />
        <field name="paperformat_id" ref="base.paperformat_us" />
    </record>

</odoo>
