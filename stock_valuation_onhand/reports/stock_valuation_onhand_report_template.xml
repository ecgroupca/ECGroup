<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_stock_valuation_onhand_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">

                    <div class="page">

                        <!-- Title block -->
                        <div class="row mb-4">
                            <div class="col-12 text-center">
                                <h2 style="font-weight:700;">
                                    Inventory Valuation – On-Hand Stock
                                </h2>
                                <h4 style="color:#555;">
                                    As of: <t t-esc="data.get('date', '')" />
                                </h4>
                                <p class="mb-0">
                                    <strong>Company:</strong>
                                    <t t-esc="data.get('company', '')" />
                                </p>
                            </div>
                        </div>

                        <!-- Data table -->
                        <table class="table table-sm table-bordered o_main_table"
                               style="font-size:10px;">
                            <thead style="background-color:#2c6496; color:#fff;">
                                <tr>
                                    <th>Company</th>
                                    <th>Location</th>
                                    <th>PO #</th>
                                    <th>Reference</th>
                                    <th>Created By</th>
                                    <th>Created On</th>
                                    <th>Product</th>
                                    <th>Category</th>
                                    <th>Stock Valuation Account</th>
                                    <th class="text-right">Qty On-Hand</th>
                                    <th>UoM</th>
                                    <th class="text-right">Unit Value</th>
                                    <th class="text-right">Total Value</th>
                                    <th class="text-right">Sales Price</th>
                                    <th class="text-right">Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="data.get('lines', [])" t-as="line">
                                    <tr>
                                        <td><t t-esc="line['company']" /></td>
                                        <td><t t-esc="line['location']" /></td>
                                        <td><t t-esc="line['po_numbers']" /></td>
                                        <td><t t-esc="line['reference']" /></td>
                                        <td><t t-esc="line['created_by']" /></td>
                                        <td><t t-esc="line['created_on']" /></td>
                                        <td><t t-esc="line['product']" /></td>
                                        <td><t t-esc="line['category']" /></td>
                                        <td style="font-size:9px;"><t t-esc="line['valuation_account']" /></td>
                                        <td class="text-right"><t t-esc="'%.4f' % line['qty']" /></td>
                                        <td><t t-esc="line['uom']" /></td>
                                        <td class="text-right">
                                            <t t-if="data.get('currency_position') == 'before'">
                                                <t t-esc="data.get('currency_symbol','')" />&#160;<t t-esc="'%.2f' % line['unit_cost']" />
                                            </t>
                                            <t t-else="">
                                                <t t-esc="'%.2f' % line['unit_cost']" />&#160;<t t-esc="data.get('currency_symbol','')" />
                                            </t>
                                        </td>
                                        <td class="text-right">
                                            <t t-if="data.get('currency_position') == 'before'">
                                                <t t-esc="data.get('currency_symbol','')" />&#160;<t t-esc="'%.2f' % line['total_value']" />
                                            </t>
                                            <t t-else="">
                                                <t t-esc="'%.2f' % line['total_value']" />&#160;<t t-esc="data.get('currency_symbol','')" />
                                            </t>
                                        </td>
                                        <td class="text-right">
                                            <t t-if="data.get('currency_position') == 'before'">
                                                <t t-esc="data.get('currency_symbol','')" />&#160;<t t-esc="'%.2f' % line['sales_price']" />
                                            </t>
                                            <t t-else="">
                                                <t t-esc="'%.2f' % line['sales_price']" />&#160;<t t-esc="data.get('currency_symbol','')" />
                                            </t>
                                        </td>
                                        <td class="text-right">
                                            <t t-if="data.get('currency_position') == 'before'">
                                                <t t-esc="data.get('currency_symbol','')" />&#160;<t t-esc="'%.2f' % line['cost']" />
                                            </t>
                                            <t t-else="">
                                                <t t-esc="'%.2f' % line['cost']" />&#160;<t t-esc="data.get('currency_symbol','')" />
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                            <tfoot>
                                <tr style="font-weight:700; background-color:#f0f0f0;">
                                    <td colspan="12" class="text-right">Grand Total</td>
                                    <td class="text-right">
                                        <t t-if="data.get('currency_position') == 'before'">
                                            <t t-esc="data.get('currency_symbol','')" />&#160;<t t-esc="'%.2f' % (data.get('grand_total') or 0)" />
                                        </t>
                                        <t t-else="">
                                            <t t-esc="'%.2f' % (data.get('grand_total') or 0)" />&#160;<t t-esc="data.get('currency_symbol','')" />
                                        </t>
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Footer note -->
                        <div class="row mt-3">
                            <div class="col-12">
                                <small class="text-muted">
                                    * Quantities reflect all done stock movements into/out of
                                    internal warehouse locations up to end of
                                    <t t-esc="data.get('date', '')" />.
                                    Unit Value is the weighted-average cost from stock
                                    valuation layers as of that date.
                                    Sales Price and Cost are current values from the product page.
                                </small>
                            </div>
                        </div>

                    </div><!-- /page -->
                </t><!-- /external_layout -->
        </t>
    </template>

</odoo>
